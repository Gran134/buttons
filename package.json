{
  "name": "Buttons",
  "displayName": "Buttons",
  "description": "Custom buttons",
  "version": "1.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "Buttons.compile",
        "title": "Compile",
        "icon": "$(beaker)"
      },
      {
        "command": "Buttons.start",
        "title": "Play",
        "icon": "$(play)"
      }

    ],
    "menus": {
      "editor/title": [
        {
          "command": "Buttons.compile",
          "group": "navigation"
        },
        {
          "command": "Buttons.start",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.5.0",
    "typescript-eslint": "^8.56.1",
    "eslint": "^10.0.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Gran134/buttons"
  }
}
